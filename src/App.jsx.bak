}

/* SERVICES (WITH FULLSCREEN IMAGE) */
function Services() {
  const [video, setVideo] = useState(null);
  const [isTouchDevice, setIsTouchDevice] = useState(false);

  useEffect(() => {
    setIsTouchDevice(("ontouchstart" in window) ||
                    (navigator.maxTouchPoints > 0) ||
                    (navigator.msMaxTouchPoints > 0));
  }, []);

  const handleHover = (videoEl, play) => {
    if (!videoEl) return;
    if (play) videoEl.play().catch(() => {}); // Catch autoplay permission errors on mobile
    else {
      videoEl.pause();
      videoEl.currentTime = 0;
    }
  };

  const handleTouchStart = (e) => {
    if (isTouchDevice) {
      const video = e.currentTarget.querySelector("video");
      handleHover(video, true);
    }
  };

  const handleTouchEnd = (e) => {
    if (isTouchDevice) {
      const video = e.currentTarget.querySelector("video");
      handleHover(video, false);
    }
  };

  return (
    <section>
      <h2 className="title">Services</h2>

      <div className="grid">
        {/* FACADE */}
        <div
          className="card video-card"
          onMouseEnter={(e) =>
            !isTouchDevice && handleHover(e.currentTarget.querySelector("video"), true)
          }
          onMouseLeave={(e) =>
            !isTouchDevice && handleHover(e.currentTarget.querySelector("video"), false)
          }
          onTouchStart={handleTouchStart}
          onTouchEnd={handleTouchEnd}
          onClick={() => setVideo("/videos/facade.mp4")}
        >
          {/* 🖼️ THUMBNAIL */}
          <img src="./images/facade.jpeg" className="thumb" />

          {/* 🎥 VIDEO PREVIEW */}
          <video src="./videos/facade.mp4" muted loop playsInline />

          <div className="overlay">
            <h3>Facade Mapping</h3>
          </div>
        </div>

        {/* PRODUCT */}
        <div
          className="card video-card"
          onMouseEnter={(e) =>
            !isTouchDevice && handleHover(e.currentTarget.querySelector("video"), true)
          }
          onMouseLeave={(e) =>
            !isTouchDevice && handleHover(e.currentTarget.querySelector("video"), false)
          }
          onTouchStart={handleTouchStart}
          onTouchEnd={handleTouchEnd}
          onClick={() => setVideo("./videos/product.mp4")}
        >
          <img src="./images/product.png" className="thumb" />
          <video src="./videos/product.mp4" muted loop playsInline />

          <div className="overlay">
            <h3>Product Launch</h3>
          </div>
        </div>

        {/* INTERACTIVE */}
        <div
          className="card video-card"
          onMouseEnter={(e) =>
            !isTouchDevice && handleHover(e.currentTarget.querySelector("video"), true)
          }
          onMouseLeave={(e) =>
            !isTouchDevice && handleHover(e.currentTarget.querySelector("video"), false)
          }
          onTouchStart={handleTouchStart}
          onTouchEnd={handleTouchEnd}
          onClick={() => setVideo("./videos/interactive.mp4")}
        >
          <img src="./images/interactive.jpeg" className="thumb" />
          <video src="./videos/interactive.mp4" muted loop playsInline />

          <div className="overlay">
            <h3>Interactive Tech</h3>
          </div>
        </div>

        {/* BRAND */}
        <div className="card">
          <h3>Brand Activations</h3>
        </div>
      </div>

      {/* 🔥 FULLSCREEN VIDEO */}
      {video && (
        <div className="fullscreen" onClick={() => setVideo(null)}>
          <video src={video} autoPlay controls />
        </div>
      )}
    </section>
  );
}

