import React, { useRef, useEffect, useState } from "react";
import { Canvas, useFrame, useThree } from "@react-three/fiber";
import { Points, PointMaterial } from "@react-three/drei";
import gsap from "gsap";

/* 🌌 BACKGROUND PARTICLES */
function Particles() {
  const ref = useRef();
  const mouse = useRef({ x: 0, y: 0 });
  const [isTouchDevice, setIsTouchDevice] = useState(false);

  // Reduce particle count on mobile devices
  const particleCount = isTouchDevice ? 3000 : 8000;
  const particles = new Float32Array(particleCount * 3).map(
    () => (Math.random() - 0.5) * 15
  );

  useEffect(() => {
    // Detect if device supports touch
    const isTouchable = () => {
      return (("ontouchstart" in window) ||
              (navigator.maxTouchPoints > 0) ||
              (navigator.msMaxTouchPoints > 0));
    };

    setIsTouchDevice(isTouchable());

    // For good measure, also check if navigator.maxTouchPoints > 0
    if (navigator.maxTouchPoints > 0 || "ontouchstart" in window) {
      setIsTouchDevice(true);
    }
  }, []);

  useEffect(() => {
    if (isTouchDevice) return; // Skip mouse tracking on touch devices

    const move = (e) => {
      mouse.current.x = (e.clientX / window.innerWidth - 0.5) * 2;
      mouse.current.y = (e.clientY / window.innerHeight - 0.5) * 2;
    };
    window.addEventListener("mousemove", move);
    return () => window.removeEventListener("mousemove", move);
  }, [isTouchDevice]);

  useFrame(() => {
    if (!ref.current) return;
    ref.current.rotation.y += 0.0002;
    if (!isTouchDevice) {
      ref.current.position.x += (mouse.current.x * 1.5 - ref.current.position.x) * 0.02;
      ref.current.position.y += (mouse.current.y * 1.5 - ref.current.position.y) * 0.02;
    }
  });

  return (
    <Points ref={ref} positions={particles}>
      <PointMaterial size={0.015} color="#00F0FF" transparent opacity={0.9} />
    </Points>
  );
}

/* 🎥 CAMERA */
function CameraController() {
  const { camera } = useThree();
  const mouse = useRef({ x: 0, y: 0 });
  const [isTouchDevice, setIsTouchDevice] = useState(false);

  useEffect(() => {
    // Detect if device supports touch
    const isTouchable = () => {
      return (("ontouchstart" in window) ||
              (navigator.maxTouchPoints > 0) ||
              (navigator.msMaxTouchPoints > 0));
    };

    setIsTouchDevice(isTouchable());
  }, []);

  useEffect(() => {
    const handleMouseMove = (e) => {
      if (isTouchDevice) return; // Disable mouse tracking on touch devices
      mouse.current.x = (e.clientX / window.innerWidth - 0.5) * 2;
      mouse.current.y = (e.clientY / window.innerHeight - 0.5) * 2;
    };

    window.addEventListener("mousemove", handleMouseMove);

    const handleScroll = () => {
      const scrollY = window.scrollY;

      gsap.to(camera.position, {
        z: 5 + scrollY * 0.002,
        y: -scrollY * 0.001,
        duration: 1,
        ease: "power3.out",
      });
    };

    window.addEventListener("scroll", handleScroll);
    return () => {
      window.removeEventListener("mousemove", handleMouseMove);
      window.removeEventListener("scroll", handleScroll);
    };
  }, [camera, isTouchDevice]);

  useFrame(() => {
    if (!isTouchDevice) {
      camera.rotation.y += (mouse.current.x * 0.1 - camera.rotation.y) * 0.05;
      camera.rotation.x += (-mouse.current.y * 0.1 - camera.rotation.x) * 0.05;
    }
  });

  return null;
}


